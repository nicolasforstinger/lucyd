# Mistral — official API
# Copy to mistral.toml and customize. The .example file is committed as a template.
type = "mistral"
api_key_env = "LUCYD_MISTRAL_KEY"
currency = "EUR"

[models.primary]
model = "mistral-large-latest"
max_tokens = 8192
max_context_tokens = 128000
cost_per_mtok = [2.0, 6.0, 0.0, 0.0]   # [input, output, cache_read, cache_write]
