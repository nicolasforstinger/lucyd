# OpenAI — embeddings
# Copy to openai.toml and customize. The .example file is committed as a template.
type = "openai"
api_key_env = "LUCYD_OPENAI_KEY"
base_url = "https://api.openai.com/v1"
currency = "USD"

[models.embeddings]
model = "text-embedding-3-small"
cost_per_mtok = [0.02, 0.0, 0.0, 0.0]   # [input, output, cache_read, cache_write]
