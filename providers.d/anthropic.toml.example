# Anthropic — official API (direct)
# Copy to anthropic.toml and customize. The .example file is committed as a template.
type = "anthropic-compat"
api_key_env = "LUCYD_ANTHROPIC_KEY"

[models.primary]
model = "claude-sonnet-4-6"
max_tokens = 65536
max_context_tokens = 200000
cost_per_mtok = [3.0, 15.0, 0.3]   # [input, output, cache_read]
cache_control = true
thinking_enabled = true
thinking_mode = "adaptive"          # "adaptive" | "budgeted" | "disabled"
supports_vision = true              # Enable image input for this model
# thinking_budget = 10000           # Only used when thinking_mode = "budgeted"
# thinking_effort = "high"          # Only used with adaptive: "high" | "medium" | "low"

[models.subagent]
# Same model as primary — sub-agents are full copies of the agent (same persona, same capabilities).
# Override only if you explicitly want a cheaper model for delegated tasks.
model = "claude-sonnet-4-6"
max_tokens = 65536
max_context_tokens = 200000
cost_per_mtok = [3.0, 15.0, 0.3]
cache_control = true
thinking_enabled = true
thinking_mode = "adaptive"
supports_vision = true

[models.compaction]
model = "claude-sonnet-4-6"
max_tokens = 4096
cost_per_mtok = [3.0, 15.0, 0.3]
