# lucyd.toml.example — Template configuration for Lucyd daemon
# Copy to lucyd.toml and customize for your setup.
# API keys are loaded from .env via environment variables.
# All keys below are required — the daemon raises ConfigError on missing keys.

# ─── Agent Identity ───────────────────────────────────────────────

[agent]
name = "YourAgent"
workspace = "~/.lucyd/workspace"

# Context files are injected into the system prompt and consume the model's context window.
# Stable + semi-stable + tool schemas + recall = system prompt size. The remainder is available
# for conversation history. When input_tokens exceeds [behavior.compaction] threshold_tokens,
# old messages are compacted. For small-context models (4k-8k), minimize stable files.
[agent.context]
stable = ["SOUL.md", "AGENTS.md", "USER.md", "IDENTITY.md", "TOOLS.md"]
semi_stable = ["MEMORY.md"]

[agent.skills]
dir = "skills"
always_on = []

# ─── Channel ─────────────────────────────────────────────────────

[channel]
type = "telegram"        # "telegram" or "cli"
debounce_ms = 500

# Create a bot via @BotFather, get the token, set it in .env as LUCYD_TELEGRAM_TOKEN.
# Get your numeric user ID via @userinfobot. Message the bot first (required by Telegram).

[channel.telegram]
token_env = "LUCYD_TELEGRAM_TOKEN"         # Env var containing the bot token
allow_from = [123456789]                   # Your Telegram user ID (numeric)
text_chunk_limit = 4000
download_dir = "/tmp/lucyd-telegram"
reconnect_initial = 1.0                    # Initial reconnect backoff (seconds)
reconnect_max = 10.0                       # Max reconnect backoff (seconds)
reconnect_factor = 2.0                     # Exponential backoff multiplier
reconnect_jitter = 0.2                     # Random jitter fraction (0.0–1.0)
media_group_delay = 0.5                    # Seconds to wait for album photos before merging
poll_timeout = 30                          # Telegram long-polling timeout (seconds)
http_timeout = 30.0                        # httpx client timeout for API calls (seconds)
http_connect_timeout = 10.0                # httpx connection timeout (seconds)

[channel.telegram.contacts]
YourContact = 123456789                    # Your Telegram user ID

# ─── Providers ───────────────────────────────────────────────────
# Models loaded from providers.d/{name}.toml files.
# Each file defines type, api_key_env, base_url, and [models.*] sections.
# Switch providers by changing the load list — one line, no model editing.

[providers]
load = ["anthropic", "openai"]
# dir = "providers.d"  # default: providers.d/ relative to this file

# ─── HTTP API ───────────────────────────────────────────────────
# Optional REST API for external integrations (n8n, scripts, webhooks).
# Auth token is loaded from env var named by token_env.

[http]
enabled = false
host = "127.0.0.1"
port = 8100
token_env = "LUCYD_HTTP_TOKEN"                             # Env var containing the bearer token
download_dir = "/tmp/lucyd-http"                           # Temp dir for HTTP attachment downloads
max_body_bytes = 10485760                                  # Max request body size (10 MB)
callback_url = ""                                          # POST after every message ("" = disabled)
callback_token_env = ""                                    # Env var for webhook bearer token
callback_timeout = 10                                      # Webhook callback timeout (seconds)
rate_limit = 30                                            # Max requests per rate_window per sender
rate_window = 60                                           # Rate limit window (seconds)
status_rate_limit = 60                                     # Max /status requests per rate_window
rate_limit_cleanup_threshold = 1000                        # Evict stale rate limit entries above this count

# ─── Memory ──────────────────────────────────────────────────────

[memory]
db = "~/.lucyd/memory/main.sqlite"
search_top_k = 10                                          # Default result limit for memory searches
embedding_timeout = 15                                     # Embedding API request timeout (seconds)
vector_search_limit = 10000                                # Raw DB query cap for vector search
fts_min_results = 3                                        # FTS results threshold before vector fallback

[memory.consolidation]
enabled = true
min_messages = 4                                           # Minimum messages before extracting
confidence_threshold = 0.6                                 # Minimum confidence for extracted facts
max_extraction_chars = 50000                               # Truncation limit for session text fed to LLM

[memory.maintenance]
enabled = true
stale_threshold_days = 90                                  # Remove unaccessed facts older than this

[memory.evolution]
enabled = true
model = "primary"                                          # Model role (default: "primary")
files = ["MEMORY.md", "USER.md"]                           # Workspace files to evolve (order matters)
anchor_file = "IDENTITY.md"                                # Identity anchor — read but never modified
max_log_chars = 80000                                      # Max chars of daily logs fed to evolution
max_facts = 50                                             # Max structured facts in context
max_episodes = 20                                          # Max episodes in context

[memory.recall]
decay_rate = 0.03                                          # Exponential decay factor for relevance scoring
max_facts_in_context = 20                                  # Maximum facts injected into context
max_dynamic_tokens = 1500                                  # Token budget for dynamic recall (0 = unlimited)
max_episodes_at_start = 3                                  # Maximum episodes injected at session start
archive_messages = 20                                      # Messages from last archived session included in recall

# Recall personality — priority controls drop order (higher = kept longer under budget pressure)
[memory.recall.personality]
priority_vector = 35                                       # Priority for vector search results
priority_episodes = 25                                     # Priority for episode blocks
priority_facts = 15                                        # Priority for fact blocks
priority_commitments = 40                                  # Priority for commitment blocks
fact_format = "natural"                                    # "natural" (readable) or "compact"
show_emotional_tone = true                                 # Include emotional tone in episode display
episode_section_header = "Recent conversations"            # Header for episode section
synthesis_style = "structured"                             # "structured" (raw), "narrative", or "factual"
# synthesis_prompt_narrative and synthesis_prompt_factual are only required when
# synthesis_style is set to "narrative" or "factual". See docs/configuration.md.
synthesis_prompt_narrative = ""
synthesis_prompt_factual = ""

[memory.indexer]
include_patterns = ["memory/*.md", "MEMORY.md"]
exclude_dirs = []
chunk_size_chars = 1600                                    # Characters per text chunk
chunk_overlap_chars = 320                                  # Overlap between chunks (for context continuity)
embed_batch_limit = 100                                    # Max chunks per embedding API batch call

# ─── Tools ───────────────────────────────────────────────────────

[tools]
enabled = [
    "read", "write", "edit", "exec",
    "web_search", "web_fetch",
    "memory_search", "memory_get",
    "memory_write", "memory_forget", "commitment_update",
    "message", "react",
    "schedule_message", "list_scheduled",
    "session_status",
    "sessions_spawn", "load_skill",
    "tts",
]
output_truncation = 30000                                  # Truncate tool output beyond this many characters
plugins_dir = "plugins.d"                                  # Directory for custom tool plugins
exec_timeout = 120                                         # Default exec tool timeout (seconds)
exec_max_timeout = 600                                     # Maximum allowed exec timeout (seconds)
subagent_deny = ["sessions_spawn", "tts", "react", "schedule_message"]  # Tools denied to sub-agents
subagent_max_turns = 0                                     # Max turns for sub-agents (0 = use max_turns_per_message)
subagent_timeout = 0                                       # Timeout for sub-agents in seconds (0 = use agent_timeout_seconds)

[tools.filesystem]
allowed_paths = ["~/.lucyd/workspace", "/tmp/"]            # Path prefixes the agent can read/write
default_read_limit = 2000                                  # Max lines returned by the read tool

[tools.web_search]
provider = "brave"                                         # Web search provider (currently only "brave")
api_key_env = "LUCYD_BRAVE_KEY"                            # Env var for web search API key
timeout = 15                                               # Web search request timeout (seconds)

[tools.web_fetch]
timeout = 15                                               # Web fetch request timeout (seconds)

[tools.tts]
provider = "elevenlabs"                                    # TTS provider name (required if tts enabled)
api_key_env = "LUCYD_ELEVENLABS_KEY"                       # Env var for TTS API key
default_voice_id = "your-elevenlabs-voice-id"
default_model_id = "eleven_v3"                             # Provider-specific model ID
speed = 1.0
stability = 0.5
similarity_boost = 0.75
timeout = 60                                               # TTS API request timeout (seconds)
api_url = "https://api.elevenlabs.io/v1/text-to-speech/{voice_id}"  # TTS endpoint ({voice_id} placeholder)

[tools.scheduling]
max_scheduled = 50                                         # Max concurrent scheduled messages
max_delay = 86400                                          # Max delay in seconds (24 hours)

# ─── Speech-to-Text ──────────────────────────────────────────────

[stt]
backend = "openai"                                         # "openai" (cloud) or "local" (whisper.cpp server)
voice_label = "voice message"                              # Label prefixed to transcriptions
voice_fail_msg = "voice message — transcription failed"    # Label on failure
audio_label = "audio transcription"                        # Label for non-voice audio files
audio_fail_msg = "audio transcription — failed"            # Label when audio transcription fails

[stt.openai]
api_url = "https://api.openai.com/v1/audio/transcriptions"
model = "whisper-1"
timeout = 60

# [stt.local]
# endpoint = "http://whisper-server:8082/inference"
# language = "auto"
# ffmpeg_timeout = 30
# request_timeout = 60

# ─── Documents ───────────────────────────────────────────────────
# Extract text from document attachments (PDF, text files, etc.)
# so the agent sees content, not just "[attachment: file.pdf, application/pdf]".
# PDF support requires pypdf (pip install pypdf).

[documents]
enabled = true
max_chars = 30000                                          # Truncation limit
max_file_bytes = 10485760                                  # 10 MB — skip huge files
text_extensions = [
    ".txt", ".md", ".csv", ".json", ".xml", ".yaml", ".yml",
    ".html", ".htm", ".py", ".js", ".ts", ".sh", ".toml",
    ".ini", ".cfg", ".log", ".sql", ".css",
]

# ─── Vision ─────────────────────────────────────────────────────

[vision]
max_image_bytes = 5242880                                  # Max inbound image size (5 MB)
max_dimension = 1568                                       # Max px on longest side
default_caption = "image"                                  # Default caption for image attachments
too_large_msg = "image too large to display"               # Message when image exceeds size limit
jpeg_quality_steps = [85, 60, 40]                          # JPEG quality reduction steps for fitting images
caption_max_chars = 200                                    # Max chars from response embedded in image caption

# ─── Behavior ────────────────────────────────────────────────────

[behavior]
silent_tokens = ["NO_REPLY"]                               # Replies matching these are not delivered
typing_indicators = true                                   # Send typing indicator before processing
error_message = "I'm having trouble connecting right now. Try again in a moment."
agent_timeout_seconds = 600                                # Timeout per API call in the agentic loop
max_turns_per_message = 50                                 # Max tool-use iterations per inbound message
max_cost_per_message = 5.0                                 # USD circuit breaker per message (0.0 = disabled)
api_retries = 2                                            # API-level retries for transient errors (429, 5xx, connection)
api_retry_base_delay = 2.0                                 # Initial backoff delay for API retries (seconds)
message_retries = 2                                        # Message-level retries on persistent failure
message_retry_base_delay = 30                              # Base delay between message retries (seconds)
audit_truncation_limit = 500                               # Max chars per message in audit log truncation
queue_capacity = 1000                                      # Max messages in the async queue
queue_poll_interval = 1.0                                  # Queue poll cycle (seconds)
quote_max_chars = 200                                      # Max chars for quoted reply context
sqlite_timeout = 30                                        # SQLite connection timeout (seconds) for all DBs
primary_sender = ""                                        # Route notifications to this sender's session ("" = disabled)
passive_notify_refs = []                                   # Notification refs buffered passively without LLM calls
telemetry_max_age = 30.0                                   # Max age (seconds) for buffered telemetry injection

# Compaction — summarizes old messages when tokens exceed threshold
[behavior.compaction]
threshold_tokens = 150000                                  # Trigger compaction when input_tokens exceeds this
warning_pct = 0.8                                          # Fraction of threshold at which to inject context warning
min_messages = 4                                           # Minimum messages before compaction can trigger
keep_recent_pct = 0.33                                     # Keep newest fraction of messages verbatim (0.0–1.0)
keep_recent_pct_min = 0.05                                 # Floor for keep_recent_pct
keep_recent_pct_max = 0.9                                  # Ceiling for keep_recent_pct
max_tokens = 2048                                          # Max output tokens for compaction summary
tool_result_max_chars = 2000                               # Max chars per tool result kept in compacted context
verify_enabled = true                                      # Post-hoc verification (structural + grounding)
verify_max_turn_labels = 3                                 # Max dialogue turn patterns before rejection
verify_grounding_threshold = 0.5                           # Min fraction of distinctive tokens grounded in source

# Compaction prompt — {agent_name} and {max_tokens} substituted
prompt = """Summarize this conversation.
Rules:
1. Return ONLY the summary text — no preamble, no labels, no commentary.
2. Write as a dense narrative (200-600 words).
3. NEVER reproduce individual message turns, timestamps, or "user:"/"assistant:" labels.
4. NEVER invent, fabricate, or extend content beyond what appears in the transcript.
5. If something was discussed, state WHAT was discussed and any conclusions reached.
6. Hard limit: {max_tokens} tokens. Be concise.
Preserve with full fidelity:
- Decisions made and reasoning behind them
- Commitments, promises, plans (who, what, when)
- New information learned
- Tasks, reminders, or follow-ups mentioned"""

# Diary prompt — used by --compact / POST /compact, {date} substituted
diary_prompt = """[AUTOMATED DAILY MAINTENANCE]

Write a memory log for {date}.

RULES:
1. Use the 'write' tool to create the file: memory/{date}.md
2. Write 100-400 words summarizing today's conversations.
3. Include: topics discussed, decisions made, commitments with deadlines, important moments.
4. Write as a first-person diary entry.
5. If the file already exists, overwrite it completely.
6. Do NOT add any text response. ONLY use the write tool."""

# ─── Logging ────────────────────────────────────────────────────

[logging]
max_bytes = 10485760                                       # Max log file size before rotation (10 MB)
backup_count = 3                                           # Number of rotated log backups to keep
suppress = ["httpx", "httpcore", "anthropic", "openai"]    # Third-party loggers suppressed to WARNING

# ─── Paths ───────────────────────────────────────────────────────

[paths]
state_dir = "~/.lucyd"
sessions_dir = "~/.lucyd/sessions"
cost_db = "~/.lucyd/cost.db"
log_file = "~/.lucyd/lucyd.log"
