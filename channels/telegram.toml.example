# Telegram bridge configuration
# Copy to telegram.toml and fill in your values.
# Secrets stay in environment variables — this file only names them.

# ─── Daemon Connection ──────────────────────────────────────────────
# How to reach the Lucyd daemon. Same for every bridge.

[daemon]
url = "http://127.0.0.1:8100"           # Daemon HTTP API
token_env = "LUCYD_HTTP_TOKEN"           # Env var for API auth (must match daemon's [http] token_env)

# ─── Telegram ───────────────────────────────────────────────────────
# Create a bot via @BotFather. Set the token in your environment.
# Get your numeric user ID via @userinfobot.

[telegram]
token_env = "LUCYD_TELEGRAM_TOKEN"       # Env var containing the bot token
allow_from = [123456789]                 # Telegram user IDs allowed to message the bot

# Tuning (all optional — defaults are sensible)
# text_chunk_limit = 4000                # Max chars per Telegram message (splits longer replies)
# poll_timeout = 30                      # Long-polling timeout (seconds)
# http_timeout = 45.0                    # httpx client timeout — must exceed poll_timeout
# http_connect_timeout = 10.0            # httpx connection timeout
# reconnect_initial = 1.0               # Initial reconnect backoff (seconds)
# reconnect_max = 10.0                  # Max reconnect backoff
# reconnect_factor = 2.0                # Exponential backoff multiplier
# reconnect_jitter = 0.2                # Random jitter fraction (0.0–1.0)
# media_group_delay = 0.5               # Seconds to wait for album photos before merging
# max_attachment_bytes = 0              # Max attachment size (0 = no limit)

# ─── Contacts ───────────────────────────────────────────────────────
# Name → Telegram user ID mapping. Used for display names in sessions.

[telegram.contacts]
# YourName = 123456789
