# Email bridge configuration
# Copy to email.toml and fill in your values.
# Secrets stay in environment variables — this file only names them.

# ─── Daemon Connection ──────────────────────────────────────────────
# How to reach the Lucyd daemon. Same for every bridge.

[daemon]
url = "http://127.0.0.1:8100"           # Daemon HTTP API
token_env = "LUCYD_HTTP_TOKEN"           # Env var for API auth (must match daemon's [http] token_env)

# ─── Email ──────────────────────────────────────────────────────────
# IMAP for receiving, SMTP for sending. Both use SSL.

[email]
imap_host = "imap.example.com"           # IMAP server (SSL)
smtp_host = "smtp.example.com"           # SMTP server (SSL)
user_env = "LUCYD_EMAIL_USER"            # Env var for email username
password_env = "LUCYD_EMAIL_PASSWORD"    # Env var for email password
folder = "INBOX"                         # IMAP folder to poll
poll_interval = 60                       # Seconds between IMAP polls
# from_address = ""                      # Reply-from address (default: same as user)
