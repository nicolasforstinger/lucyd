# ElevenLabs text-to-speech plugin config.
# Copy to elevenlabs.toml and customize.

api_key_env = "LUCYD_ELEVENLABS_KEY"
api_url = "https://api.elevenlabs.io/v1/text-to-speech/{voice_id}"
default_voice_id = "your-voice-id"
default_model_id = "eleven_v3"
timeout = 60

[voice]
speed = 1.0
stability = 0.5
similarity_boost = 0.75

# Cost tracking — amortized from your ElevenLabs plan.
# Example: Starter plan ($6/mo, 30k credits ~ 30k chars) -> $6/30 = $0.20 per 1k chars.
[cost]
per_1k_chars = 0.20
currency = "USD"
