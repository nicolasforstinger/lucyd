#!/usr/bin/env bash
# Provision a new Lucyd agent.
#
# Creates the deployment directory, database, Docker network, Prometheus
# target, Gitea repo, and starts the container.  Reads LUCYD_BIND_IP from
# the environment (default: 127.0.0.1).
#
# Usage:
#   bin/provision --client nicolas --agent luna [--port 8101] [--telegram] [--email]

set -euo pipefail

# ── Defaults ─────────────────────────────────────────────────────────

BIND_IP="${LUCYD_BIND_IP:-127.0.0.1}"
CLIENTS_DIR="/srv/clients"
INFRA_DIR="/srv/infrastructure"
REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"  # lucyd source root
PG_CONTAINER="lucyd-postgres"
PG_SUPERUSER="lucyd"

CLIENT=""
AGENT=""
PORT=""
WITH_TELEGRAM=false
WITH_EMAIL=false

# ── Argument parsing ─────────────────────────────────────────────────

usage() {
    echo "Usage: $0 --client NAME --agent NAME [--port PORT] [--telegram] [--email]"
    exit 1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --client)  CLIENT="$2"; shift 2 ;;
        --agent)   AGENT="$2";  shift 2 ;;
        --port)    PORT="$2";   shift 2 ;;
        --telegram) WITH_TELEGRAM=true; shift ;;
        --email)    WITH_EMAIL=true;    shift ;;
        -h|--help) usage ;;
        *) echo "Unknown option: $1"; usage ;;
    esac
done

[[ -z "$CLIENT" || -z "$AGENT" ]] && usage

# ── Validation ───────────────────────────────────────────────────────

validate_name() {
    local name="$1" label="$2"
    if ! [[ "$name" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
        echo "ERROR: ${label} must be lowercase alphanumeric + hyphens: ${name}" >&2
        exit 1
    fi
}

validate_name "$CLIENT" "client"
validate_name "$AGENT"  "agent"

AGENT_DIR="${CLIENTS_DIR}/${CLIENT}/agents/${AGENT}"
if [[ -d "$AGENT_DIR" ]]; then
    echo "ERROR: Agent directory already exists: ${AGENT_DIR}" >&2
    exit 1
fi

# ── Port assignment ──────────────────────────────────────────────────

if [[ -z "$PORT" ]]; then
    # Scan existing compose files for the highest mapped host port.
    HIGHEST=$(grep -rhoPm1 '\d+(?=:8100)' "${CLIENTS_DIR}"/*/agents/*/docker-compose.yml 2>/dev/null \
        | sort -n | tail -1)
    PORT=$(( ${HIGHEST:-8099} + 1 ))
fi

# Verify port not in use.
if ss -tlnp 2>/dev/null | grep -q ":${PORT} "; then
    echo "ERROR: Port ${PORT} is already in use" >&2
    exit 1
fi

echo "==> Provisioning ${CLIENT}/${AGENT} on port ${PORT}"

# ── Docker network ───────────────────────────────────────────────────

NETWORK="client-${CLIENT}"
if ! docker network inspect "$NETWORK" >/dev/null 2>&1; then
    echo "--- Creating Docker network: ${NETWORK}"
    docker network create "$NETWORK"
fi

# ── Postgres database ────────────────────────────────────────────────

DB_NAME="lucyd_${CLIENT}_${AGENT}"
DB_USER="lucyd_${CLIENT}_${AGENT}"
# Replace hyphens with underscores for valid SQL identifiers.
DB_NAME="${DB_NAME//-/_}"
DB_USER="${DB_USER//-/_}"
DB_PASS="$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)"

echo "--- Creating database: ${DB_NAME}"

# Source postgres superuser password if available.
PG_ENV="${INFRA_DIR}/postgres/.env"
if [[ -f "$PG_ENV" ]]; then
    PG_PASS="$(grep '^POSTGRES_PASSWORD=' "$PG_ENV" | cut -d= -f2-)"
    export PGPASSWORD="$PG_PASS"
fi

docker exec "$PG_CONTAINER" psql -U "$PG_SUPERUSER" -c \
    "CREATE USER ${DB_USER} WITH PASSWORD '${DB_PASS}';" 2>/dev/null || true
docker exec "$PG_CONTAINER" psql -U "$PG_SUPERUSER" -c \
    "CREATE DATABASE ${DB_NAME} OWNER ${DB_USER};" 2>/dev/null || true
docker exec "$PG_CONTAINER" psql -U "$PG_SUPERUSER" -d "$DB_NAME" -c \
    "CREATE EXTENSION IF NOT EXISTS vector;" 2>/dev/null || true

unset PGPASSWORD

# ── Directory structure ──────────────────────────────────────────────

echo "--- Creating directory: ${AGENT_DIR}"
mkdir -p "${AGENT_DIR}"/{providers.d,plugins.d,data/{workspace,sessions,logs,downloads}}

# ── .env ─────────────────────────────────────────────────────────────

HTTP_TOKEN="$(openssl rand -base64 12 | tr -d '/+=' | head -c 16)"

cat > "${AGENT_DIR}/.env" << EOF
LUCYD_DATABASE_URL=postgres://${DB_USER}:${DB_PASS}@host.docker.internal:5432/${DB_NAME}
LUCYD_HTTP_TOKEN=${HTTP_TOKEN}
LUCYD_ANTHROPIC_KEY=
LUCYD_OPENAI_KEY=
LUCYD_BRAVE_KEY=
LUCYD_ELEVENLABS_KEY=
LUCYD_TELEGRAM_TOKEN=
EOF

# ── lucyd.toml ───────────────────────────────────────────────────────

AGENT_DISPLAY="$(echo "${AGENT:0:1}" | tr '[:lower:]' '[:upper:]')${AGENT:1}"

cat > "${AGENT_DIR}/lucyd.toml" << EOF
# Generated by bin/provision — customize as needed.

[agent]
name = "${AGENT_DISPLAY}"
workspace = "/data/workspace"
client_id = "${CLIENT}"
id = "${AGENT}"

[agent.context]
stable = ["SOUL.md"]
semi_stable = ["MEMORY.md"]

[agent.skills]
dir = "skills"
always_on = []

[providers]
load = ["anthropic", "openai"]

[http]
host = "0.0.0.0"
port = 8100
token_env = "LUCYD_HTTP_TOKEN"
trust_localhost = true
download_dir = "/tmp/lucyd-http"
max_body_bytes = 10485760
rate_limit = 120
rate_window = 60
status_rate_limit = 300

[database]
url_env = "LUCYD_DATABASE_URL"
pool_min = 2
pool_max = 10

[memory]
search_top_k = 10

[memory.consolidation]
enabled = true
confidence_threshold = 0.6

[memory.maintenance]
stale_threshold_days = 90

[memory.recall]
decay_rate = 0.03
max_facts_in_context = 20
max_dynamic_tokens = 4000
max_episodes_at_start = 3

[memory.indexer]
include_patterns = ["memory/*.md", "MEMORY.md"]
chunk_size_chars = 1600
chunk_overlap_chars = 320
embed_batch_limit = 100

[tools]
enabled = [
    "read", "write", "edit", "exec",
    "web_search", "web_fetch",
    "memory_search", "memory_get",
    "memory_write", "memory_forget", "commitment_update",
    "session_status", "sessions_spawn", "load_skill",
]
output_truncation = 30000
plugins_dir = "plugins.d"
exec_timeout = 120
exec_max_timeout = 600
subagent_deny = ["sessions_spawn"]

[tools.filesystem]
allowed_paths = ["/data/workspace/", "/tmp/"]
default_read_limit = 2000

[tools.web_search]
provider = "brave"
api_key_env = "LUCYD_BRAVE_KEY"

[documents]
enabled = true
max_chars = 30000
max_file_bytes = 10485760
pdf_max_render_pages = 5

[vision]
max_image_bytes = 5242880
max_dimension = 1568
jpeg_quality_steps = [85, 60, 40]

[behavior]
debounce_ms = 500
typing_indicators = true
agent_timeout_seconds = 600
max_turns_per_message = 50
max_cost_per_message = 5.0
api_retries = 2
api_retry_base_delay = 2.0
message_retries = 2
message_retry_base_delay = 30

[behavior.compaction]
threshold_tokens = 150000
warning_pct = 0.8
min_messages = 4
keep_recent_pct = 0.33
max_tokens = 2048

[logging]
suppress = ["httpx", "httpcore", "anthropic", "openai"]

[paths]
state_dir = "/data"
log_file = "/data/lucyd.log"

[conversion]
api_url = "http://host.docker.internal:8080/v2/rate/EUR/USD"
static_rate = 1.15
EOF

# ── Provider configs ─────────────────────────────────────────────────

for f in "${REPO_DIR}"/providers.d/*.toml.example; do
    [[ -f "$f" ]] || continue
    base="$(basename "$f" .example)"
    cp "$f" "${AGENT_DIR}/providers.d/${base}"
done

# ── docker-compose.yml ───────────────────────────────────────────────

BRIDGES=""
if $WITH_TELEGRAM; then BRIDGES="\"--with-telegram\""; fi
if $WITH_EMAIL; then
    [[ -n "$BRIDGES" ]] && BRIDGES="${BRIDGES}, "
    BRIDGES="${BRIDGES}\"--with-email\""
fi
[[ -n "$BRIDGES" ]] && BRIDGES="[${BRIDGES}]"

cat > "${AGENT_DIR}/docker-compose.yml" << EOF
services:
  ${CLIENT}-${AGENT}:
    image: ghcr.io/nicolasforstinger/lucyd:latest
    container_name: ${CLIENT}-${AGENT}
EOF

# Only add command if bridges were specified.
if [[ -n "$BRIDGES" ]]; then
    cat >> "${AGENT_DIR}/docker-compose.yml" << EOF
    command: ${BRIDGES}
EOF
fi

cat >> "${AGENT_DIR}/docker-compose.yml" << EOF
    ports:
      - "${BIND_IP}:${PORT}:8100"
    volumes:
      - ./lucyd.toml:/config/lucyd.toml:ro
      - ./providers.d:/config/providers.d:ro
      - ./plugins.d:/config/plugins.d:ro
      - ./.env:/config/.env:ro
      - ./data:/data
    env_file: .env
    environment:
      - LUCYD_CONFIG=/config/lucyd.toml
    extra_hosts:
      - "host.docker.internal:host-gateway"
    stop_grace_period: 30s
    restart: unless-stopped
    networks:
      - ${NETWORK}
    labels:
      lucyd.client: ${CLIENT}
      lucyd.agent: ${AGENT}
      lucyd.role: agent

networks:
  ${NETWORK}:
    external: true
EOF

# ── Prometheus target ────────────────────────────────────────────────

TARGETS_DIR="${INFRA_DIR}/monitoring/prometheus/targets"
TARGETS_FILE="${TARGETS_DIR}/${CLIENT}.json"
mkdir -p "$TARGETS_DIR"

python3 - "$TARGETS_FILE" "$PORT" "$CLIENT" "$AGENT" "$BIND_IP" << 'PYEOF'
import json, sys

path, port, client, agent, bind_ip = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5]
try:
    with open(path) as f:
        targets = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    targets = []

targets.append({
    "targets": [f"{bind_ip}:{port}"],
    "labels": {
        "client": client,
        "agent": agent,
        "container": f"{client}-{agent}",
    },
})

with open(path, "w") as f:
    json.dump(targets, f, indent=2)
PYEOF

echo "--- Registered Prometheus target: ${BIND_IP}:${PORT}"

# ── Git + Gitea ──────────────────────────────────────────────────────

cat > "${AGENT_DIR}/.gitignore" << 'EOF'
data/sessions/
data/logs/
data/downloads/
EOF

cd "$AGENT_DIR"
git init -q
git add -A
git commit -q -m "initial: ${CLIENT}/${AGENT}"

# Create Gitea repo if the SSH alias exists.
GITEA_HOST="gitea-${CLIENT}"
if ssh -o BatchMode=yes -o ConnectTimeout=3 "$GITEA_HOST" 2>/dev/null; then
    # Gitea SSH API: pushing to a non-existent repo creates it.
    git remote add origin "${GITEA_HOST}:${CLIENT}/${AGENT}.git"
    git push -u origin main 2>/dev/null && echo "--- Pushed to Gitea" \
        || echo "WARN: Gitea push failed — set up remote manually"
else
    echo "WARN: SSH alias '${GITEA_HOST}' not reachable — skipping Gitea setup"
fi

# ── Auto-commit crontab ─────────────────────────────────────────────

SCRIPTS_DIR="${CLIENTS_DIR}/${CLIENT}/scripts"
mkdir -p "$SCRIPTS_DIR"

AUTOCOMMIT="${SCRIPTS_DIR}/auto-commit.sh"
if [[ ! -f "$AUTOCOMMIT" ]]; then
    cat > "$AUTOCOMMIT" << 'ACEOF'
#!/bin/bash
# Auto-commit and push agent configs + workspace changes.
# Runs hourly via cron. Exits silently if nothing changed.

BASE="$(dirname "$0")/.."

# Agent repos
for dir in "${BASE}"/agents/*/; do
    [ -d "${dir}.git" ] || continue
    cd "${dir}"
    git add -A
    git diff --staged --quiet && continue
    git commit -q -m "auto: $(date +%Y-%m-%d_%H:%M)" || continue
    git push 2>/dev/null || true
done

# Infrastructure repo
if [ -d "/srv/infrastructure/.git" ]; then
    cd /srv/infrastructure
    git add -A
    git diff --staged --quiet || {
        git commit -q -m "auto: $(date +%Y-%m-%d_%H:%M)"
        git push 2>/dev/null || true
    }
fi
ACEOF
    chmod +x "$AUTOCOMMIT"
    echo "--- Created auto-commit script"
fi

# Add crontab entry if not present.
CRON_CMD="5 * * * * ${AUTOCOMMIT}"
if ! crontab -l 2>/dev/null | grep -qF "$AUTOCOMMIT"; then
    (crontab -l 2>/dev/null; echo "$CRON_CMD") | crontab -
    echo "--- Added crontab entry for auto-commit"
fi

# ── Start container ──────────────────────────────────────────────────

echo "--- Starting container"
cd "$AGENT_DIR"
docker compose up -d

# ── Summary ──────────────────────────────────────────────────────────

echo ""
echo "=========================================="
echo "  Agent provisioned: ${CLIENT}/${AGENT}"
echo "=========================================="
echo "  Directory:   ${AGENT_DIR}"
echo "  Container:   ${CLIENT}-${AGENT}"
echo "  Port:        ${BIND_IP}:${PORT}"
echo "  Database:    ${DB_NAME}"
echo "  DB User:     ${DB_USER}"
echo "  HTTP Token:  ${HTTP_TOKEN}"
echo "  Network:     ${NETWORK}"
echo ""
echo "  Next steps:"
echo "    1. Fill in API keys in ${AGENT_DIR}/.env"
echo "    2. Customize lucyd.toml (personality, tools, etc.)"
echo "    3. Add workspace files: ${AGENT_DIR}/data/workspace/"
echo "    4. Restart after config changes: cd ${AGENT_DIR} && docker compose up -d"
echo ""
