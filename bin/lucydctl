#!/usr/bin/env python3
"""lucydctl — Lucyd daemon CLI.

Thin HTTP client — all commands go through the daemon's HTTP API.

Send:
    lucydctl --message "Hello"                    # User message (sync)
    lucydctl --message "Question" --from Claudio  # Message from named sender
    lucydctl --system "Run diagnostics"           # System event
    lucydctl --notify "Invoice ready" --source n8n --ref INV-42
    lucydctl --evolve                             # Trigger memory evolution
    lucydctl --compact                            # Force diary + compaction
    lucydctl --index                              # Run workspace indexing
    lucydctl --index --full                       # Force full re-index
    lucydctl --consolidate                        # Extract facts from workspace files
    lucydctl --maintain                           # Run memory maintenance

Query:
    lucydctl --status                             # Daemon status
    lucydctl --cost 2026-03                       # Cost records (JSON)
    lucydctl --sessions                           # Active sessions
    lucydctl --monitor                            # Agentic loop state
    lucydctl --history Nicolas                    # Session transcript
    lucydctl --index-status                       # Workspace index status

Reset:
    lucydctl --reset                              # Reset ALL sessions
    lucydctl --reset system                       # Reset system session
    lucydctl --reset <session-uuid>               # Reset by ID
"""

import argparse
import base64
import json
import mimetypes
import os
import sys
from pathlib import Path

import httpx


# ─── HTTP Transport ──────────────────────────────────────────────


def _url() -> str:
    return os.environ.get("LUCYD_URL", "http://127.0.0.1:8100")


def _auth() -> dict:
    token = os.environ.get("LUCYD_HTTP_TOKEN", "")
    if token:
        return {"Authorization": f"Bearer {token}"}
    return {}


def _http_get(path: str, params: dict | None = None) -> dict:
    resp = httpx.get(f"{_url()}/api/v1/{path}", params=params,
                     headers=_auth(), timeout=30)
    resp.raise_for_status()
    return resp.json()


def _http_post(path: str, body: dict, timeout: float = 300) -> dict:
    resp = httpx.post(f"{_url()}/api/v1/{path}", json=body,
                      headers=_auth(), timeout=timeout)
    resp.raise_for_status()
    return resp.json()


def _output(data) -> None:
    print(json.dumps(data, indent=2, default=str))


# ─── Attachment Encoding ─────────────────────────────────────────


def _encode_attachments(paths: list[str]) -> list[dict]:
    """Base64-encode local files for HTTP transport."""
    result = []
    for filepath in paths:
        p = Path(filepath).resolve()
        if not p.exists():
            print(f"Error: file not found: {p}", file=sys.stderr)
            sys.exit(1)
        if not p.is_file():
            print(f"Error: not a file: {p}", file=sys.stderr)
            sys.exit(1)
        ct, _ = mimetypes.guess_type(str(p))
        data = base64.b64encode(p.read_bytes()).decode("ascii")
        result.append({
            "content_type": ct or "application/octet-stream",
            "filename": p.name,
            "data": data,
        })
    return result


# ─── Main ─────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        prog="lucydctl",
        description="Lucyd daemon CLI — all commands via HTTP API",
    )

    send = parser.add_argument_group("Send")
    send.add_argument("-m", "--message", metavar="TEXT", help="User message (sync — waits for response)")
    send.add_argument("-s", "--system", metavar="TEXT", help="System event")
    send.add_argument("-n", "--notify", metavar="TEXT", help="Notification")
    send.add_argument("--evolve", action="store_true", help="Trigger memory evolution")
    send.add_argument("--compact", action="store_true", help="Force diary + compaction")
    send.add_argument("--index", action="store_true", help="Run workspace indexing")
    send.add_argument("--index-status", action="store_true", help="Show workspace index status")
    send.add_argument("--consolidate", action="store_true", help="Extract facts from workspace files")
    send.add_argument("--maintain", action="store_true", help="Run memory maintenance")
    send.add_argument("--reset", nargs="?", const="all", metavar="TARGET",
                      help="Reset session (name, UUID, or 'all')")

    query = parser.add_argument_group("Query")
    query.add_argument("--status", action="store_true", help="Daemon status")
    query.add_argument("--cost", nargs="?", const="", metavar="PERIOD",
                       help="Cost records (YYYY-MM, default: current month)")
    query.add_argument("--sessions", action="store_true", help="Active sessions")
    query.add_argument("--monitor", action="store_true", help="Agentic loop state")
    query.add_argument("--history", nargs="?", const="__default__", metavar="TARGET",
                       help="Session history (contact name or session ID)")

    opts = parser.add_argument_group("Options")
    opts.add_argument("--from", dest="sender", metavar="NAME",
                      help="Sender name (default: 'cli' for --message)")
    opts.add_argument("--source", metavar="SOURCE",
                      help="Notification source (requires --notify)")
    opts.add_argument("--ref", metavar="REF",
                      help="Notification reference (requires --notify)")
    opts.add_argument("--data", metavar="JSON",
                      help="Notification metadata as JSON (requires --notify)")
    opts.add_argument("--full", action="store_true",
                      help="Full mode: all events with --history, force re-index with --index")
    opts.add_argument("-a", "--attach", action="append", metavar="FILE",
                      help="Attach file(s) (repeatable)")

    args = parser.parse_args()

    # ── Validate ──────────────────────────────────────────────────
    if args.attach and not (args.message or args.system or args.notify):
        parser.error("--attach requires --message, --system, or --notify")
    if (args.source or args.ref or args.data) and not args.notify:
        parser.error("--source, --ref, and --data require --notify")
    if args.full and args.history is None and not args.index:
        parser.error("--full requires --history or --index")

    try:
        # ── Query commands ────────────────────────────────────────
        if args.status:
            _output(_http_get("status"))
            return

        if args.cost is not None:
            params = {"period": args.cost} if args.cost else {}
            _output(_http_get("cost", params))
            return

        if args.sessions:
            _output(_http_get("sessions"))
            return

        if args.monitor:
            _output(_http_get("monitor"))
            return

        if args.history is not None:
            if args.history == "__default__":
                print("Usage: lucydctl --history <contact_or_session_id>", file=sys.stderr)
                sys.exit(1)
            params = {"full": "true"} if args.full else {}
            _output(_http_get(f"sessions/{args.history}/history", params))
            return

        # ── Send commands ─────────────────────────────────────────
        if args.evolve:
            _output(_http_post("evolve", {}))
            return

        if args.compact:
            _output(_http_post("compact", {}))
            return

        if args.index:
            body = {"full": True} if args.full else {}
            _output(_http_post("index", body, timeout=600))
            return

        if args.index_status:
            _output(_http_get("index/status"))
            return

        if args.consolidate:
            _output(_http_post("consolidate", {}, timeout=600))
            return

        if args.maintain:
            _output(_http_post("maintain", {}))
            return

        if args.reset is not None:
            _output(_http_post("sessions/reset", {"target": args.reset}))
            return

        if not args.message and not args.system and not args.notify:
            parser.print_help()
            sys.exit(1)

        # Build body
        attachments = _encode_attachments(args.attach) if args.attach else None

        if args.message:
            body: dict = {"message": args.message}
            if args.sender:
                body["sender"] = args.sender
            if attachments:
                body["attachments"] = attachments
            _output(_http_post("chat", body))

        elif args.system:
            body = {"message": args.system}
            if args.sender:
                body["sender"] = args.sender
            if attachments:
                body["attachments"] = attachments
            _output(_http_post("system", body))

        elif args.notify:
            body = {"message": args.notify}
            if args.sender:
                body["sender"] = args.sender
            if args.source:
                body["source"] = args.source
            if args.ref:
                body["ref"] = args.ref
            if args.data:
                try:
                    body["data"] = json.loads(args.data)
                except json.JSONDecodeError:
                    print("Error: --data must be valid JSON", file=sys.stderr)
                    sys.exit(1)
            if attachments:
                body["attachments"] = attachments
            _output(_http_post("notify", body))

    except httpx.ConnectError:
        print("Error: cannot connect to daemon. Is it running?", file=sys.stderr)
        sys.exit(1)
    except httpx.HTTPStatusError as e:
        try:
            err = e.response.json()
            print(json.dumps(err, indent=2), file=sys.stderr)
        except Exception:
            print(f"Error: HTTP {e.response.status_code}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
