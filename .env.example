# Copy to .env and fill in your keys.

# Required: at least one provider key matching a providers.d/*.toml api_key_env
LUCYD_ANTHROPIC_KEY=
LUCYD_OPENAI_KEY=
LUCYD_MISTRAL_KEY=

# PostgreSQL connection (required only if [database] is set in lucyd.toml)
LUCYD_DATABASE_URL=postgres://lucyd:lucyd@localhost:5432/lucyd

# HTTP API bearer token (required only if [http] token_env is set in lucyd.toml)
LUCYD_HTTP_TOKEN=

# Optional integrations
LUCYD_TELEGRAM_TOKEN=
LUCYD_ELEVENLABS_KEY=
LUCYD_BRAVE_KEY=
